<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/img"
    tools:context=".Password"
    android:padding="30dp">

    <View
        android:layout_width="60dp"
        android:layout_height="4dp"
        android:layout_marginTop="20dp"
        android:background="#FF0057"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:fontFamily="@font/chrsuty"
        android:gravity="center"
        android:letterSpacing="-0.02"
        android:text="Passport Scan"
        android:textColor="#FF0057"
        android:textSize="44sp"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSample"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/nasa"
        android:letterSpacing="0.1"
        android:text="Example: AA 1234567"
        android:textColor="#FF0057"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <EditText
        android:id="@+id/passportEditText"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_marginTop="45dp"
        android:background="@drawable/passport_input_bg"
        android:fontFamily="@font/chrsuty"
        android:gravity="center"
        android:hint="SERIES and NUMBER"
        android:inputType="textCapCharacters"
        android:letterSpacing="0.2"
        android:maxLength="9"
        android:padding="15dp"
        android:textColor="#FF0057"
        android:textColorHint="#88FF0057"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/tvSample" />

    <androidx.cardview.widget.CardView
        android:id="@+id/resultContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:cardBackgroundColor="#12FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/passportEditText">

        <TextView
            android:id="@+id/resultTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/shorttt"
            android:gravity="center"
            android:padding="20dp"
            android:text="Waiting for input..."
            android:textColor="#FF0057"
            android:textSize="16sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <android.widget.Button
        android:id="@+id/checkButton"
        android:layout_width="0dp"
        android:layout_height="75dp"
        android:layout_marginBottom="40dp"
        android:layout_marginHorizontal="30dp"
        android:background="@drawable/passport_input_bg"
        android:fontFamily="@font/fere"
        android:stateListAnimator="@null"
        android:text="Verify Identity"
        android:textAllCaps="false"
        android:textColor="#FF0057"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>